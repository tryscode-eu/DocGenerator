# Exemple de forme : amqps://user:secret@rabbitmq:5671/vhost
RABBITMQ_URL=
RABBITMQ_SOCKET_TIMEOUT_SECONDS=3
RABBITMQ_STACK_TIMEOUT_SECONDS=5
RABBITMQ_BLOCKED_TIMEOUT_SECONDS=3
RABBITMQ_HEARTBEAT_SECONDS=30
DOCUMENT_QUEUE=document_tasks
DOCUMENT_RETRY_QUEUE=document_tasks.retry
DOCUMENT_ARCHIVE_QUEUE=document_tasks.archive
DOCUMENT_MAX_RETRIES=5
DOCUMENT_RETRY_DELAY_SECONDS=30
# Secret aléatoire dédié (32–256 caractères ASCII), distinct du token Harmony.
DOCUMENT_RETRY_SIGNING_KEY=
DOCUMENT_RETRY_MAX_MESSAGES=10000
DOCUMENT_RETRY_MAX_BYTES=536870912
DOCUMENT_ARCHIVE_TTL_MS=604800000
DOCUMENT_ARCHIVE_MAX_MESSAGES=10000
DOCUMENT_OUTPUT_DIR=/data/documents
DOCUMENT_STORAGE_MODE=local
DOCUMENT_STORAGE_PREFIX=documents
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=tryscode
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
S3_PREFIX=
S3_CONNECT_TIMEOUT_SECONDS=3
S3_READ_TIMEOUT_SECONDS=10
S3_MAX_ATTEMPTS=2
HARMONY_CALLBACK_URL=https://harmony.example.invalid/api/v1/jobs/callback
# Secret dédié à l'identité `document-worker` dans Harmony API_SERVICE_TOKENS.
HARMONY_SERVICE_TOKEN=
DOCUMENT_CALLBACK_TIMEOUT_SECONDS=5
DEBUG=false
